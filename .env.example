# 复制为 .env；遗留 OLLAMA_* 仍可读

LOG_LEVEL=INFO
SERVER_LOG_LEVEL=WARNING
LOG_ID_CHARS=8
# 默认：时间 + 级别 + 消息（业务日志已含单号/task，无需冗长模块路径）
LOG_FORMAT=<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <7}</level> | <level>{message}</level>
# 调试定位可开短模块名（chat_tasks:144），勿用完整 name:function:line
# LOG_LOC_SHORT=true

# uvicorn API（默认不热重载；开发可设 UVICORN_RELOAD=true，仅监听 app/api 等目录，不含 app/tasks）
# UVICORN_HOST=0.0.0.0
# UVICORN_PORT=9099
# UVICORN_RELOAD=false
# UVICORN_RELOAD_DIRS=app/api,app/core,app/providers,app/services,app/schemas,app/session

# Redis：Celery broker + LLM 会话存储（默认共用同一实例）
REDIS_URL=redis://localhost:6379/0
LLM_SESSION_BACKEND=redis
CELERY_WORKER_CONCURRENCY=3
# Ctrl+C 后最多等待正在跑的任务收尾（秒），超时后 cold shutdown；仍卡住请用 scripts/celery_worker.sh stop
CELERY_WORKER_SOFT_SHUTDOWN_TIMEOUT=15
# 注册哪些 Celery 任务包：llm | chat | sing | tts | all（逗号分隔）
CELERY_TASK_PACKAGES=llm

CALLBACK_HOST=localhost
CALLBACK_PORT=8080

# LLM 闲聊总闸（Bot 侧也需 LLM_CHAT_ENABLED=true）
LLM_CHAT_ENABLED=true

# ── Provider 与 chain 分流 ─────────────────────────────────────────────
# 模式：local_only（仅 Ollama）| remote_only（仅远端 API）| chain（按 task 分流 + 可回退）
LLM_PROVIDER_MODE=local_only

# chain 模式下：某 provider 失败时是否尝试链中下一个（try_next | fail）
LLM_CHAIN_ORDER=local,remote
LLM_CHAIN_ON_FAILURE=try_next

# chain 模式下：按 metadata.task 固定走本地或远端（逗号分隔，改 .env 即可，无需改代码）
# 可选 task 名（与 Bot 传入的 metadata.task 一致）：
#   llm_chat           — @ 对话、私聊 LLM
#   drunk              — 醉聊模式
#   repeater_fallback  — 接话兜底（无匹配语料时短句生成）
#   repeater_select    — 接话选句（命中语料，输出编号；推荐 simple 小模型，不经 categorizer）
#   repeater_polish    — 接话润色（遗留）
#
# 判定顺序：先查 REMOTE 列表且远端已配置 → 仅 remote；再查 LOCAL → 仅 local；
# 都不在列表 → 按 LLM_CHAIN_ORDER 链式回退。
# 同一 task 若写入两个列表：优先走远端（LOCAL 侧等同无效）。
#
# 【预设 A】@ / 醉聊走本地，接话走远端（省本地算力、接话质量靠 Flash）
# LLM_CHAIN_LOCAL_TASKS=llm_chat,drunk
# LLM_CHAIN_REMOTE_TASKS=repeater_fallback,repeater_polish,repeater_select
#
# 【预设 B】接话走本地，@ 走远端（本地 tools 弱、接话占显存）
# LLM_CHAIN_LOCAL_TASKS=repeater_fallback,repeater_polish,repeater_select
# LLM_CHAIN_REMOTE_TASKS=llm_chat,drunk
#
# 下方为预设 A 的展开写法（mode=chain 时取消注释并填写远端 LLM_REMOTE_*）
LLM_CHAIN_LOCAL_TASKS=llm_chat,drunk
LLM_CHAIN_REMOTE_TASKS=repeater_fallback,repeater_polish

# 本地推理 HTTP 后端（Docker 全栈常用 http://ollama:11434）
LLM_BACKEND_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:7b
LLM_AUTO_START=false
LLM_BACKEND_BINARY=ollama
LLM_AUTO_PULL=true
LLM_STARTUP_TIMEOUT=60
LLM_MAX_HISTORIES=100
LLM_TEMPERATURE=0.55
# Ollama num_gpu 层数；WebUI「模型与推理」可热改运行时，长期默认仍写在此键
LLM_NUM_GPU=12
LLM_REQUEST_TIMEOUT=90
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF=1.0
LLM_DRUNK_TEMPERATURE=1.0

# 远端 OpenAI 兼容 API（remote_only 或 chain 且 task 落在 REMOTE 列表时使用）
# LLM_REMOTE_BASE_URL=https://api.deepseek.com
# LLM_REMOTE_API_KEY=
# LLM_REMOTE_MODEL=deepseek-chat

# 路由：manual | moe
# providers.toml：复制 config/providers.example.toml
# LLM_PROVIDERS_FILE=config/providers.toml
LLM_ROUTING=manual
LLM_MOE_ENABLED=false
# LLM_MOE_MODEL_SIMPLE=
# LLM_MOE_MODEL_MEDIUM=
# LLM_MOE_MODEL_COMPLEX=
# 含图 @对话专用视觉模型（未配置时回退 MoE tier 路由；须为 Ollama 支持的 VLM）：
# LLM_MOE_MODEL_VISION=llava:7b
# LLM_MOE_REMOTE_MODEL_VISION=
# Bot 会将 CQ 图片 url 写入 metadata.vision_image_urls，AI 侧拉取后注入 Ollama images 字段。
# 配置 ≥2 档本地模型时自动按 categorizer tier 选模型（无需 LLM_MOE_ENABLED=true）
# 按 MoE tier 将部分 @对话 切到远端（仍保留 task 级 local/remote 分流）：
# LLM_MOE_TIER_REMOTE_TIERS=complex          # 命中 tier 时优先 remote，可写 complex,medium
# LLM_MOE_TIER_REMOTE_TASKS=llm_chat,drunk   # 默认即此
# LLM_MOE_TIER_REMOTE_FALLBACK=local         # remote 失败时回退 local；none=不回退
# LLM_MOE_REMOTE_MODEL_COMPLEX=deepseek-v4-flash

# 按 task + provider 覆盖模型名（可选；未设则用 LLM_MODEL / LLM_REMOTE_MODEL）
# 本地侧（provider=local）：
# LLM_TASK_MODEL_CHAT=
# LLM_TASK_MODEL_DRUNK=
# LLM_TASK_MODEL_REPEATER_FALLBACK=
# LLM_TASK_MODEL_REPEATER_POLISH=
# 远端侧（provider=remote）：
# LLM_TASK_MODEL_CHAT_REMOTE=
# LLM_TASK_MODEL_DRUNK_REMOTE=
# LLM_TASK_MODEL_REPEATER_FALLBACK_REMOTE=
# LLM_TASK_MODEL_REPEATER_POLISH_REMOTE=

# LLM_SESSION_BACKEND=memory  # 仅单进程本地调试；生产与多 worker 必须用 redis

LLM_TOOLS_ENABLED=true
LLM_TOOLS_SELECTIVE=true
LLM_CATEGORIZER_ENABLED=true
LLM_CATEGORIZER_PROVIDER=local
LLM_CATEGORIZER_MODEL=qwen2.5:0.5b
# LLM_MOE_MODEL_SIMPLE=qwen2.5:0.5b  # <3 字 @对话/润色；需 tool 时仍抬到 medium
PERSONA_AFFECT_REFINE_ENABLED=true    # 群风格情感 refine，默认 true
# PERSONA_AFFECT_REFINE_TIMEOUT_SEC=90   # 同步超时，排队等 Ollama 时建议 ≥60
# PERSONA_AFFECT_REFINE_MAX_CONCURRENT=1 # uvicorn 侧直连 Ollama 并发上限

# ── Image Runtime（Phase 2；Bot draw 插件 ai_service_runtime 模式调用）────────
# IMAGE_ENABLED=false
# IMAGE_BASE_URL=https://api.openai.com
# IMAGE_API_KEY=
# IMAGE_MODEL=gpt-image-1
# IMAGE_REQUEST_TIMEOUT=180
# IMAGE_OPEN_CIRCUIT_FAILURES=3
# IMAGE_CIRCUIT_COOLDOWN_SEC=120
# IMAGE_OMIT_RESPONSE_FORMAT=true
# IMAGE_REF_DOWNLOAD_TIMEOUT=60

# ── Media Tasks（Phase 5；慢路径 image.generate / media.sing 统一任务模型）────
# 提交：POST /api/media/tasks
# 查询：GET /api/media/tasks/{task_id}
# 观测：GET /api/media/tasks/runtime
# MEDIA_TASK_TTL_SEC=86400
