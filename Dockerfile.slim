# LLM-only 瘦镜像：无 CUDA、不装 sing/tts/chat 媒体依赖，不预拉模型。
# 构建: docker build -f Dockerfile.slim -t pallasbot/pallas-bot-ai:slim .
# 全功能 GPU 镜像仍用 Dockerfile → :latest / :cuda12.4-*

FROM python:3.12-slim-bookworm AS builder

ENV PIP_NO_CACHE_DIR=1
ENV UV_CACHE_DIR=/tmp/uv-cache
ENV UV_LINK_MODE=copy

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    build-essential \
    && curl -LsSf https://astral.sh/uv/install.sh | sh \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/root/.local/bin:$PATH"

WORKDIR /build
COPY pyproject.toml uv.lock ./

# 仅主依赖（LLM API + Celery redis），不含 dependency-groups sing/tts/chat
RUN uv venv --python 3.12 \
    && uv sync --frozen --no-dev \
    && find /build/.venv -name "*.pyc" -delete \
    && find /build/.venv -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true \
    && rm -rf /tmp/uv-cache /root/.cache

FROM python:3.12-slim-bookworm AS runtime

ENV PYTHONUNBUFFERED=1
ENV PATH="/server/.venv/bin:$PATH"
ENV AI_ENABLE_MEDIA_WORKER=0
ENV CELERY_TASK_PACKAGES=llm

LABEL org.opencontainers.image.title="Pallas-Bot AI (slim)"
LABEL org.opencontainers.image.description="LLM-only AI Runtime without CUDA or media workers"
LABEL org.opencontainers.image.vendor="Pallas-Bot"
LABEL org.opencontainers.image.version="slim"

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /server
COPY --from=builder /build/.venv /server/.venv
RUN mkdir -p logs resource/chat/models resource/sing/models resource/tts

COPY app/ ./app/
COPY Docker/startup.slim.sh ./Docker/startup.slim.sh
RUN chmod +x /server/Docker/startup.slim.sh

EXPOSE 9099
CMD ["/server/Docker/startup.slim.sh"]
